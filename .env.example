# =============================================
# CAMPUS LOST & FOUND — Environment Variables
# =============================================
# Copy this file to .env and fill in real values
# NEVER commit .env to GitHub!

# Server
PORT=5000
NODE_ENV=development

# MongoDB (get from MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/campus-lost-found

# JWT Secret (make this long and random — minimum 32 chars)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT Expiry
JWT_EXPIRES_IN=7d

# Google Gemini AI (get free key from aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Email (Gmail SMTP — use an App Password, not your real password)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# Frontend URL (for CORS — update when deployed)
CLIENT_URL=http://localhost:3000
